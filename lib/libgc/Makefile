NAME = libgc.a

# =============================================================================
# Section : Directories
# =============================================================================

# =============================================================================
# Section : Source files
# =============================================================================

SRC =	gc_add.c \
		gc_free.c \
		gc_get.c \
		gc_search_node.c \
		gc_sweep.c \
		gc_display.c \
		gclst_addback.c \
		gclst_new.c \
		gclst_clear.c

# =============================================================================
# Section : Object files
# =============================================================================

OBJ = $(SRC:.c=.o)

# =============================================================================
# Section : Compiler and flags
# =============================================================================

CC = gcc
CFLAGS = -Wall -Wextra -Werror -I .
AR = ar -rcs
RM = rm -f

# =============================================================================
# Section : Targets
# =============================================================================

all: $(NAME)

$(NAME): $(OBJ)
	$(AR) $@ $?

%.o: %.c
	$(CC) -c $(CFLAGS) $< -o $@

clean:
	$(RM) $(OBJ)

fclean: clean
	$(RM) $(NAME)

re: fclean all

.PHONY: all clean fclean re bonus
